# ---------------------------------------------------------------------------
# Fuel Route API - environment configuration
# Copy this file to `.env` and adjust as needed.
# ALL values have safe defaults; the API runs out-of-the-box with no keys.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Routing provider (OSRM public demo - NO API KEY REQUIRED)
# One call per request returns geometry + distance + duration.
OSRM_BASE_URL=https://router.project-osrm.org
ROUTING_TIMEOUT_SECONDS=20

# Geocoding provider (Nominatim / OpenStreetMap - NO API KEY REQUIRED)
# Only used when start/finish are sent as text. Results are cached.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Nominatim usage policy requires a descriptive User-Agent / contact.
GEOCODER_USER_AGENT=fuel-route-api/1.0 (assessment@example.com)
GEOCODING_TIMEOUT_SECONDS=15

# Vehicle assumptions (the assessment fixes these; configurable for tests)
VEHICLE_MAX_RANGE_MILES=500
VEHICLE_MPG=10

# Fuel optimizer tuning
# Radius around the route within which a station counts as "on the route".
STATION_SEARCH_RADIUS_MILES=15
# Avoid refuelling stops closer together than this unless unavoidable.
MIN_LEG_MILES=50
